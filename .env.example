# Required: server-side key for the AI Espresso live demo (POST /api/try).
# The demo falls back to static story text if this is unset or the call fails,
# so the rest of the app runs without it.
ANTHROPIC_API_KEY=

# Optional: external AI Espresso demo endpoint, if running the full pipeline locally.
NEXT_PUBLIC_ESPRESSO_DEMO_API=http://localhost:8000

# Optional / deferred: Microsoft Graph for the planned tech-talk calendar integration.
# Register an app in Azure AD (Entra ID) with Calendars.ReadWrite (application) permission.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OUTLOOK_CALENDAR_USER=
# Optional: defaults to the primary calendar. Set to a specific calendar ID for a shared calendar.
OUTLOOK_CALENDAR_ID=
